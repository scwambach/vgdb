# ────────────────────────────────────────
# IGDB / Twitch
# ────────────────────────────────────────
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# The access token is fetched server-side at runtime using the two above,
# so you don't store it — but if you cache it you may want:
# IGDB_ACCESS_TOKEN=

# ────────────────────────────────────────
# Supabase
# ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=      # Server-only — never expose to the client

# ────────────────────────────────────────
# App
# ────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=           # e.g. https://retrovault.com (used for auth redirects & shared collection links)
